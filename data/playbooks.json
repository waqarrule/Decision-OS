{
  "playbooks": [
    {
      "id": "fundraising-trigger",
      "portal": "ceo",
      "title": "Fundraising Trigger",
      "subtitle": "Series C preparation pipeline",
      "category": "capital",
      "statusLabel": "Active | Monitor",
      "statusColor": "amber",
      "description": "Structured path from ARR milestone to Series C close. Each step has a data gate — no gut feelings.",
      "dataSources": ["financials", "company", "revenue-mix"],
      "costOfInaction": {
        "monthlyCost": 42000,
        "description": "Delayed Series C = $42K/mo in valuation gap growth",
        "basis": "ARR growth vs static valuation multiple erosion"
      },
      "steps": [
        {
          "id": "s1",
          "title": "ARR hits $15M",
          "statusRule": {
            "source": "company",
            "path": "company.arr",
            "operator": ">=",
            "threshold": 15000000
          },
          "completedText": "Triggered",
          "completedSince": "3 months ago"
        },
        {
          "id": "s2",
          "title": "Board approves Series C prep",
          "statusRule": {
            "source": "company",
            "path": "boardMetrics.fundraisingTarget",
            "operator": "equals",
            "value": "Series C"
          },
          "completedText": "Approved Feb 2026"
        },
        {
          "id": "s3",
          "title": "Fix burn multiple below 2×",
          "statusRule": {
            "source": "financials",
            "path": "financials.burnMultiple",
            "operator": "<",
            "threshold": 2.0
          },
          "liveValue": {
            "source": "financials",
            "path": "financials.burnMultiple",
            "format": "number",
            "suffix": "×"
          },
          "targetDisplay": "<1.8×",
          "description": "Reduce SMB acquisition spend. Focus on enterprise where LTV:CAC is 6.2× vs SMB's 2.8×",
          "recommendations": [
            {
              "label": "Cut SMB acquisition budget 30%",
              "impact": "Burn multiple drops to 1.7×",
              "detail": "SMB CAC payback is 22mo vs Enterprise's 8mo. Redirect $126K/yr to enterprise channel."
            },
            {
              "label": "Shift 2 SDRs from SMB to Enterprise",
              "impact": "Burn multiple drops to 1.8×",
              "detail": "Enterprise pipeline coverage improves from 2.8× to 3.4×. SMB pipeline already over-served."
            },
            {
              "label": "Raise SMB pricing 20%",
              "impact": "Burn multiple drops to 1.9×, some churn risk",
              "detail": "SMB NRR is 96% (below breakeven). Price-sensitive segment, expect 8-12% churn spike."
            }
          ],
          "owner": "CFO",
          "costOfDelay": 42000
        },
        {
          "id": "s4",
          "title": "Build investor deck",
          "statusRule": { "manual": true },
          "owner": "CEO",
          "dependencies": ["s3"],
          "estimatedDays": 14
        },
        {
          "id": "s5",
          "title": "Begin conversations",
          "statusRule": { "manual": true },
          "owner": "CEO",
          "targetDate": "Q3 2026",
          "dependencies": ["s4"],
          "estimatedDays": 60
        }
      ],
      "branches": {
        "s3": {
          "condition": "burn_multiple >= 2.0",
          "ifTrue": "blocked",
          "ifFalse": "proceed"
        }
      }
    },
    {
      "id": "hiring-trigger",
      "portal": "ceo",
      "title": "Hiring Trigger",
      "subtitle": "Sales team expansion gate",
      "category": "growth",
      "statusLabel": "Blocked",
      "statusColor": "red",
      "description": "Data-gated hiring. Pipeline coverage, rep productivity, and CFO scenario check must all pass before offers go out.",
      "dataSources": ["pipeline", "financials", "company"],
      "costOfInaction": {
        "monthlyCost": 144000,
        "description": "3 unfilled reps × $48K/mo revenue capacity = $144K/mo lost",
        "basis": "Average quota attainment × per-rep revenue"
      },
      "steps": [
        {
          "id": "s1",
          "title": "Pipeline coverage > 3×",
          "statusRule": {
            "source": "pipeline",
            "path": "pipeline.coverageRatio",
            "operator": ">",
            "threshold": 3.0
          },
          "completedText": "Hit 3.2× last month",
          "owner": "CRO"
        },
        {
          "id": "s2",
          "title": "Rep productivity > 85% quota",
          "statusRule": {
            "source": "pipeline",
            "path": "pipeline.quotaAttainment",
            "operator": ">",
            "threshold": 85
          },
          "completedText": "Current: 91%",
          "owner": "CRO"
        },
        {
          "id": "s3",
          "title": "CFO scenario check",
          "statusRule": {
            "source": "company",
            "path": "scenarios.bear.runwayMonths",
            "operator": ">=",
            "threshold": 12.0
          },
          "liveValue": {
            "source": "company",
            "path": "scenarios.bear.runwayMonths",
            "format": "number",
            "suffix": "mo"
          },
          "targetDisplay": "≥12mo",
          "description": "Bear scenario must show ≥12mo runway with planned hires factored in.",
          "blockReason": "Bear scenario shows 11.8mo runway with Plan hiring. Below 12mo minimum.",
          "resolutionOptions": [
            {
              "id": "opt1",
              "label": "Defer hiring 8 weeks",
              "impact": "Runway becomes 12.4mo ✓",
              "computedEffect": { "adjustMonths": 2, "resultRunway": 12.4 },
              "tradeoff": "Pipeline coverage may drop to 2.6× without new reps"
            },
            {
              "id": "opt2",
              "label": "Hire 2 instead of 3",
              "impact": "Runway becomes 12.1mo ✓",
              "computedEffect": { "reduceHires": 1, "resultRunway": 12.1 },
              "tradeoff": "Slower revenue ramp, ~$180K/yr less new ARR capacity"
            },
            {
              "id": "opt3",
              "label": "Cut marketing spend 15%",
              "impact": "Runway becomes 12.6mo ✓",
              "computedEffect": { "cutSpendPct": 15, "resultRunway": 12.6 },
              "tradeoff": "Top-of-funnel lead volume drops ~20% in 2 months"
            }
          ],
          "owner": "CFO",
          "crossPortalLink": { "portal": "cfo", "section": "scenarios", "label": "View CFO scenario calculator" },
          "costOfDelay": 144000
        },
        {
          "id": "s4",
          "title": "CEO approval",
          "statusRule": { "manual": true },
          "owner": "CEO",
          "dependencies": ["s3"],
          "estimatedDays": 3
        },
        {
          "id": "s5",
          "title": "Post roles + hire",
          "statusRule": { "manual": true },
          "owner": "HR",
          "dependencies": ["s4"],
          "estimatedDays": 30,
          "targetDate": "30-day search target"
        }
      ],
      "branches": {
        "s3": {
          "condition": "bear_runway < 12",
          "ifTrue": "blocked",
          "ifFalse": "proceed",
          "options": true
        }
      }
    }
  ]
}
